{
  "name": "component-preview",
  "displayName": "component-preview",
  "description": "Instant component previews on hover for HTML/React/Vue/Svelte in local dev.",
  "version": "0.1.0",
  "publisher": "RioEdwards",
  "author": "Rio Edwards <rioredwards@gmail.com>",
  "homepage": "https://github.com/rioredwards/component-preview",
  "icon": "images/ComponentPreview_Icon.png",
  "keywords": [
    "component-preview",
    "hover-preview",
    "preview",
    "react",
    "tsx",
    "jsx",
    "vue",
    "svelte",
    "vite",
    "developer-tools",
    "rio",
    "rio edwards",
    "rioredwards"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rioredwards/component-preview.git"
  },
  "bugs": {
    "url": "https://github.com/rioredwards/component-preview/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "vscode:publish": "node scripts/publish-marketplaces.mjs vscode",
    "package:vsix": "node scripts/publish-marketplaces.mjs package",
    "open-vsx:publish": "node scripts/publish-marketplaces.mjs open-vsx",
    "publish:all": "node scripts/publish-marketplaces.mjs all",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:demo:hover": "npm run compile-tests && npm run compile && vscode-test --grep \"shows a diagnostic hover when no matching preview target is available|renders an image hover from a configured local test server\"",
    "fixture:hover:install": "npm --prefix fixtures/hover-fixture-debug install",
    "fixture:hover:ensure": "node scripts/ensure-fixture-dev.mjs",
    "fixture:hover:dev": "npm --prefix fixtures/hover-fixture-debug install && npm --prefix fixtures/hover-fixture-debug run dev -- --host 127.0.0.1 --port 5173",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "inspect-fibers": "tsx scripts/inspect-fibers.ts"
  },
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:vue",
    "onLanguage:svelte"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "component-preview.openPluginSetup",
        "title": "Component Preview: Open Vite Plugin Setup"
      }
    ],
    "configuration": {
      "title": "Component Preview",
      "properties": {
        "component-preview.devServerUrl": {
          "type": "string",
          "default": "",
          "description": "Optional dev server URL override. Example: http://localhost:5173"
        }
      }
    }
  },
  "dependencies": {
    "node-html-parser": "^7.0.2",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@vscode/test-cli": "^0.0.12",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
